{
    "rewrites": [
        {
            "source": "/api/me",
            "destination": "/api/session?action=me"
        },
        {
            "source": "/api/logout",
            "destination": "/api/session?action=logout"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/distribution-sim",
